{
    "height": 20,
    "spacing": 0,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad"],
    "modules-right": ["custom/media", "tray", "pulseaudio", "network", "battery", "clock"],
    "sway/workspaces": {
        "enable-bar-scroll": true,
        "smooth-scrolling-threshold": 10,
        "disable-scroll-wraparound": true,
        "on-click-right": "swayswitch",
        "on-click-middle": "fuzzel",
        "cursor": false
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "´őĺ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}",
        "on-click": "swaymsg scratchpad show",
        "cursor": false
    },
    "tray": {
        "icon-size": 14,
        "spacing": 16
    },
    "clock": {
        "format": "{:%a %d %b %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
          "format": {
            "today": "<b>{}</b>"
          }
        },
        "on-click": "swaytui cal",
        "on-click-middle": "swaytui powermenu",
        "cursor": false
    },
    "sway/language": {
        "format": "{short}",
        "tooltip-format": "{long}",
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
        "cursor": false
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "´ü«",
        "deactivated": "´ü░"
      },
      "cursor": false
    },
    "temperature": {
      "hwmon-path": "/sys/devices/pci0000:00/0000:00:18.3/hwmon/hwmon2/temp1_input",
      "interval": 3,
      "critical-threshold": 80,
      "format": "{temperatureC}┬░C",
      "on-click": "foot -a sensors -T sensors -H sh -c 'watch -n1 sensors'",
      "cursor": false
    },
    "cpu": {
     "interval": 3,
     "format": "{icon0}{icon1}{icon2}{icon3}{icon4}{icon5}{icon6}{icon7}",
     "format-icons": [
          "<span color='#69ff94'>Ôľü</span>",
          "<span color='#69ff94'>Ôľé</span>",
          "<span color='#69ff94'>Ôľâ</span>",
          "<span color='#69ff94'>Ôľä</span>",
          "<span color='#ffffa5'>Ôľů</span>",
          "<span color='#ffffa5'>Ôľć</span>",
          "<span color='#ff9977'>Ôľç</span>",
          "<span color='#dd532e'>Ôľł</span>"
      ],
      "on-click": "foot -a htop -T htop htop",
      "on-click-middle": "swaytui powermenu",
      "cursor": false
    },
    "battery": {
        "states": {
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-time": "{H}:{m}h",
        "format-discharging": "{icon} {capacity}%",
        "format-charging": "´âž {capacity}%",
        "format-plugged": "´çŽ",
        "format-full": "´çŽ",
        "tooltip-format": "{capacity}% {time} {power}W",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
        "on-click": "swaytui powermanagment",
        "on-click-middle": "swaytui powermenu",
        "cursor": false
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["´üé"],
        "smooth-scrolling-threshold": 1
    },
    "network": {
        "tooltip-format": "{essid} {signalStrength}%",
        "tooltip-format-ethernet": "{ifname}",
        "format": "{icon}",
        "format-icons": {
          "wifi": "´çź",
          "ethernet": "´âé",
          "linked": "´çź (No IP)",
          "disconnected": "´çź"
        },
        "on-click": "nm-applet --indicator",
        "on-click-right": "nm-connection-editor",
        "on-click-middle": "pkill nm-applet",
        "cursor": false
    },
    "pulseaudio": {
        "format": "{icon} {volume}%  {format_source}",
        "format-muted": "´çÂ {format_source}",
        "format-source": "´ä░ {volume}%",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´Őô",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "tooltip-format": "{desc}",
        "on-click": "pavucontrol -t 3",
        "on-click-right": "blueman-manager",
        "on-click-middle": "swaytui bt",
        "smooth-scrolling-threshold": 1,
        "cursor": false
    },
    "custom/media": {
        "format": "{icon}",
        "return-type": "json",
        "format-icons": {
            "Playing": "´ůä",
            "Paused": "´Őő",
            "Stopped": "´ŐŹ"
        },
        "exec": "pgrep playerctl | head -n -$(($(swaymsg -t get_outputs -p | grep Output | wc -l)-1)) | xargs kill -9; playerctl metadata --format '{\"tooltip\": \"{{markup_escape(title)}} - {{markup_escape(artist)}} [{{playerName}}]\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
        "on-click": "playerctl play-pause",
        "on-click-right": "cmus-remote -C player-next-album || playerctl next",
        "on-click-middle": "playerctl -a stop",
        "cursor": false
    }
}
