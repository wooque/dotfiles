{
    "height": 20,
    "spacing": 0,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad"],
    "modules-right": ["custom/media", "tray", "pulseaudio", "network", "battery", "custom/brightness", "clock"],
    "sway/workspaces": {
        "enable-bar-scroll": true,
        "smooth-scrolling-threshold": 10,
        "disable-scroll-wraparound": true,
        "on-click-right": "scripts swayswitch",
        "on-click-middle": "fuzzel",
        "cursor": false
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", ""],
        "tooltip": true,
        "tooltip-format": "{app}: {title}",
        "on-click": "swaymsg scratchpad show",
        "cursor": false
    },
    "tray": {
        "icon-size": 14,
        "spacing": 16
    },
    "clock": {
        "format": "{:%a %d %b %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
          "format": {
            "today": "<b>{}</b>"
          }
        },
        "on-click": "scripts calendar",
        "on-click-middle": "scripts power-menu",
        "cursor": false
    },
    "sway/language": {
        "format": "{short}",
        "tooltip-format": "{long}",
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
        "cursor": false
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "",
        "deactivated": ""
      },
      "cursor": false
    },
    "temperature": {
      "hwmon-path": "/sys/devices/pci0000:00/0000:00:18.3/hwmon/hwmon2/temp1_input",
      "interval": 3,
      "critical-threshold": 80,
      "format": "{temperatureC}°C",
      "on-click": "foot -a sensors -T sensors -H sh -c 'watch -n1 sensors'",
      "cursor": false
    },
    "cpu": {
     "interval": 3,
     "format": "{icon0}{icon1}{icon2}{icon3}{icon4}{icon5}{icon6}{icon7}",
     "format-icons": [
          "<span color='#69ff94'>▁</span>",
          "<span color='#69ff94'>▂</span>",
          "<span color='#69ff94'>▃</span>",
          "<span color='#69ff94'>▄</span>",
          "<span color='#ffffa5'>▅</span>",
          "<span color='#ffffa5'>▆</span>",
          "<span color='#ff9977'>▇</span>",
          "<span color='#dd532e'>█</span>"
      ],
      "on-click": "foot -a htop -T htop htop",
      "on-click-middle": "scripts power-menu",
      "cursor": false
    },
    "battery": {
        "states": {
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-time": "{H}:{m}h",
        "format-discharging": "{icon} {capacity}% {power:.1f}W",
        "format-charging": " {capacity}%",
        "format-plugged": "",
        "format-full": "",
        "tooltip-format": "{capacity}% {power:.1f}W {time}",
        "format-icons": ["", "", "", "", ""],
        "on-click": "scripts power-menu",
        "cursor": false
    },
    "network": {
        "tooltip-format": "{essid} {signalStrength}%",
        "tooltip-format-ethernet": "{ifname}",
        "format": "{icon}",
        "format-icons": {
          "wifi": "",
          "ethernet": "",
          "linked": " (No IP)",
          "disconnected": ""
        },
        "on-click": "nm-applet --indicator",
        "on-click-right": "nm-connection-editor",
        "on-click-middle": "pkill nm-applet",
        "cursor": false
    },
    "pulseaudio": {
        "format": "{icon} {volume}%  {format_source}",
        "format-muted": " {format_source}",
        "format-source": " {volume}%",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "default": ["", "", ""]
        },
        "tooltip-format": "{desc}",
        "on-click": "pavucontrol -t 3",
        "on-click-right": "blueman-manager",
        "on-click-middle": "scripts bt-toggle",
        "smooth-scrolling-threshold": 1,
        "cursor": false
    },
    "custom/media": {
        "format": "{icon}",
        "return-type": "json",
        "format-icons": {
            "Playing": "",
            "Paused": "",
            "Stopped": ""
        },
        "exec": "pgrep playerctl | head -n -$(($(swaymsg -t get_outputs -p | grep Output | wc -l)-1)) | xargs kill -9; playerctl metadata --format '{\"tooltip\": \"{{markup_escape(title)}} - {{markup_escape(artist)}} [{{playerName}}]\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
        "on-click": "playerctl play-pause",
        "on-click-right": "cmus-remote -C player-next-album || playerctl next",
        "on-click-middle": "playerctl -a stop",
        "cursor": false
    },
    "custom/brightness": {
      "format": " {}",
      "return-type": "json",
      "exec": "scripts brightness",
      "on-click-middle": "brightnessctl s 50%",
      "on-scroll-up": "brightnessctl s 1%+",
      "on-scroll-down": "brightnessctl s 1%-",
      "smooth-scrolling-threshold": 1,
      "cursor": false
    }
}
