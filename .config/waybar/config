{
    "height": 20,
    "spacing": 0,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad"],
    "modules-right": ["custom/media", "tray", "pulseaudio", "network", "battery", "clock"],
    "sway/workspaces": {
        "enable-bar-scroll": true,
        "smooth-scrolling-threshold": 10,
        "disable-scroll-wraparound": true,
        "on-click-right": "scripts swayswitch",
        "on-click-middle": "fuzzel",
        "cursor": false
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", ""],
        "tooltip": true,
        "tooltip-format": "{app}: {title}",
        "on-click": "swaymsg scratchpad show",
        "cursor": false
    },
    "tray": {
        "icon-size": 14,
        "spacing": 16
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%a %d %b}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
          "format": {
            "today": "<b>{}</b>"
          }
        },
        "on-click-right": "scripts calendar",
        "on-click-middle": "scripts power-menu",
        "cursor": false
    },
    "battery": {
        "states": {
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-time": "{H}:{m}h",
        "format-discharging": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": "",
        "format-full": "",
        "tooltip-format": "{capacity}% {power:.1f}W {time}",
        "format-icons": ["", "", "", "", ""],
        "on-click": "scripts power-menu",
        "cursor": false
    },
    "network": {
        "tooltip-format": "{essid} {signalStrength}%",
        "tooltip-format-ethernet": "{ifname}",
        "format": "{icon}",
        "format-icons": {
          "wifi": "",
          "ethernet": "",
          "linked": " (No IP)",
          "disconnected": ""
        },
        "on-click": "nm-applet --indicator",
        "on-click-right": "nm-connection-editor",
        "on-click-middle": "pkill nm-applet",
        "cursor": false
    },
    "pulseaudio": {
        "format": "{icon} {volume}%  {format_source}",
        "format-muted": " {format_source}",
        "format-source": " {volume}%",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "default": ["", "", ""]
        },
        "tooltip-format": "{desc}",
        "on-click": "pavucontrol -t 3",
        "on-click-right": "blueman-manager",
        "on-click-middle": "scripts bt-toggle",
        "smooth-scrolling-threshold": 1,
        "cursor": false
    },
    "custom/media": {
        "format": "{icon}",
        "return-type": "json",
        "format-icons": {
            "Playing": "",
            "Paused": "",
            "Stopped": ""
        },
        "exec": "pgrep playerctl | head -n -$(($(swaymsg -t get_outputs -p | grep Output | wc -l)-1)) | xargs kill -9; playerctl metadata --format '{\"tooltip\": \"{{markup_escape(title)}} - {{markup_escape(artist)}} [{{playerName}}]\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
        "on-click": "playerctl play-pause",
        "on-click-right": "cmus-remote -C player-next-album || playerctl next",
        "on-click-middle": "playerctl -a stop",
        "cursor": false
    }
}
