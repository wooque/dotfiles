{
    "height": 20,
    "spacing": 0,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad"],
    "modules-right": ["custom/media", "tray", "pulseaudio", "network", "custom/data-usage", "battery", "clock"],
    "sway/workspaces": {
        "enable-bar-scroll": true,
        "smooth-scrolling-threshold": 10,
        "disable-scroll-wraparound": true,
        "on-click-right": "scripts swayswitch",
        "on-click-middle": "fuzzel",
        "cursor": false
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "яЛТ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}",
        "on-click": "swaymsg scratchpad show",
        "cursor": false
    },
    "tray": {
        "icon-size": 14,
        "spacing": 16
    },
    "clock": {
        "format": "{:%a %d %b %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
          "format": {
            "today": "<b>{}</b>"
          }
        },
        "on-click": "scripts calendar",
        "on-click-middle": "scripts power-menu",
        "cursor": false
    },
    "battery": {
        "states": {
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-time": "{H}:{m}h",
        "format-discharging": "{icon} {capacity}%",
        "format-charging": "яГз {capacity}%",
        "format-plugged": "яЗж",
        "format-full": "яЗж",
        "tooltip-format": "{capacity}% {power:.1f}W {time}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
        "on-click": "scripts power-menu",
        "cursor": false
    },
    "network": {
        "format-wifi": "яЗл",
        "tooltip-format-wifi": "{essid} {signalStrength}%",
        "format-ethernet": "яГВ",
        "tooltip-format-ethernet": "{ifname}",
        "format-linked": "яВм",
        "tooltip-format-linked": "no ip address",
        "format-disconnected": "яВм",
        "tooltip-format-disconnected": "disconnected",
        "format-disabled": "яВм",
        "tooltip-format-disabled": "disabled",
        "on-click": "nm-applet --indicator",
        "on-click-right": "nm-connection-editor",
        "on-click-middle": "pkill nm-applet",
        "cursor": false
    },
    "custom/data-usage": {
      "format": "яДй",
      "return-type": "json",
      "exec": "scripts data-usage",
      "interval": 5
    },
    "pulseaudio": {
        "format": "{icon} {volume}%  {format_source}",
        "format-muted": "яЗ╢ {format_source}",
        "format-source": "яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яКУ",
            "default": ["яАж", "яАз", "яАи"]
        },
        "tooltip-format": "{desc}",
        "on-click": "pavucontrol -t 3",
        "on-click-right": "blueman-manager",
        "on-click-middle": "scripts bt-toggle",
        "smooth-scrolling-threshold": 1,
        "cursor": false
    },
    "custom/media": {
        "format": "{icon}",
        "return-type": "json",
        "format-icons": {
            "Playing": "яЕД",
            "Paused": "яКЛ",
            "Stopped": "яКН"
        },
        "exec": "pgrep playerctl | head -n -$(($(swaymsg -t get_outputs -p | grep Output | wc -l)-1)) | xargs kill -9; playerctl metadata --format '{\"tooltip\": \"{{markup_escape(title)}} - {{markup_escape(artist)}} [{{playerName}}]\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
        "on-click": "playerctl play-pause",
        "on-click-right": "cmus-remote -C player-next-album || playerctl next",
        "on-click-middle": "playerctl -a stop",
        "cursor": false
    }
}
