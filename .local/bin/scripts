#!/usr/bin/bash
function backup_mail() {
  echo "thunderbird sync..."
  timeout 15 thunderbird --headless
}
function backup_data() {
  echo "rclone sync..."
  rclone sync -lv --fast-list --transfers 32 --delete-excluded --exclude-from /mnt/PODACI/.backupignore /mnt/PODACI b2-crypt: 2>&1 | tee ~/backup-$(date +%Y-%m-%d-%H-%M-%S).log
}
function backup_dropbox() {
  echo "dropbox sync..."
  dropbox start && sleep 15 && dropbox stop
}
function backup() {
  backup_mail
  backup_data
  backup_dropbox
}

function autostart() {
  if [ "$(cat /sys/class/power_supply/ACAD/online)" = "0" ]; then
    echo "Not starting on battery"
  else
    find ~/.config/autostart/ \( -type f -o -type l \) ! -empty -exec exo-open {} \;
  fi
}

function system-end() {
  bluetoothctl disconnect
  rm -rf ~/.cache/cliphist
  systemctl "$@"
}
function power-menu() {
  local poweroff=" Power off"
  local reboot=" Reboot"
  local suspend=" Suspend"
  local commands="$poweroff\n$reboot\n$suspend"
  local row=$(printf "$commands" | sed 's/.*/&/' | fuzzel -d)

  if [[ "$row" =~ "$poweroff" ]]; then
      system-end poweroff
  elif [[ "$row" =~ "$reboot" ]]; then
      system-end reboot
  elif [[ "$row" =~ "$suspend" ]]; then
      system-end suspend
  fi
}

function bt-toggle() {
  if bluetoothctl devices Connected | grep -q Device; then
    bluetoothctl disconnect
  else
    blueman-manager
  fi
}

function notify-keyboard() {
  makoctl dismiss -g

  local lang="$(swaymsg -t get_inputs | jq -r 'map(select(has("xkb_active_layout_name")))[0].xkb_active_layout_name')"
  notify-send " $lang"
}
function notify-brightness() {
  makoctl dismiss -g

  local dev="/sys/class/backlight/amdgpu_bl0"
  local max=$(cat "$dev/max_brightness")
  local actual=$(cat "$dev/actual_brightness")
  local current=$(cat "$dev/brightness")
  local actual_p="$(( ((100*actual) + (max/2)) / $max))"
  local current_p="$(( ((100*current) + (max/2)) / $max))"

  notify-send " $current_p% (actual $actual_p%)"
}

function data-usage() {
  local default_ifname=$(ip route | awk '/default/ {print $5; exit}')

  ip -s -h link show | awk -v default_ifname="$default_ifname" '
  /^[0-9]+:/ {
      if ($2 != "lo:") {
          ifname = $2
          sub(/:$/, "", ifname)

          is_default = (ifname == default_ifname)
          get_stats = 1
      } else {
          get_stats = 0
      }
  }
  get_stats && /RX:/ {
      getline; rx = $1
  }
  get_stats && /TX:/ {
      getline; tx = $1

      if (is_default) {
          printf "\033[1m↓ %s ↑ %s %s\033[0m\n", rx, tx, ifname
      } else {
          printf "↓ %s ↑ %s %s\n", rx, tx, ifname
      }
  }'
}

function kanshi-start() {
  sleep 0.5
  killall -q kanshi
  sleep 0.5
  kanshi > ~/.kanshi.log 2>&1 &
}

function cmus-refresh() {
  cmus-remote -c -l
  cmus-remote -C "add /mnt/PODACI/muzika"
  cmus-remote -C "update-cache -f"
}
function cmus-start() {
  foot -a cmus -T cmus cmus &
  sleep 0.5
  cmus-refresh
  sleep 2.5
  cmus-remote -p
}

function swayswitch() {
  sleep 0.05
  local row=$(swaymsg -t get_tree | jq  -r '
      ..
      | objects
      | select(.type == "workspace") as $ws
      | ..
      | objects
      | select(has("app_id"))
      | (if .focused == true then "*" else " " end) as $asterisk
      | "[\($ws.num)] \($asterisk) \(.app_id) | \(.name) | <\(.id)>"' \
  | fuzzel -d -w 60)

  if [ ! -z "$row" ]
  then
      local winid=$(echo "$row" | sed 's/.*<\([0-9]*\)>.*/\1/')
      swaymsg "[con_id=$winid] focus"
  fi
}

function show-data-usage() {
  foot -a data-usage -T "data usage" -H -o "cursor.color=000000 ffffff" -o font=monospace:size=16 watch -t scripts data-usage
}
function calendar() {
  foot -a calendar -T calendar -H -o "cursor.color=000000 ffffff" -o font=monospace:size=10.5 sh -c 'ncal -bM -B3 -A8'
}
function open-recent() {
  recent | fuzzel -d -w 80 | sed -n 's/.*(\(.*\)).*/\1/p' | xargs xdg-open
}
function screenshot-region() {
   grim -g "$(slurp)" && notify-send " screenshot taken"
}
function screenshot-window() {
  swaymsg -t get_tree | jq -r '.. | select(.pid? and .visible?) | "\(.rect.x + .window_rect.x),\(if .deco_rect.width != 0 and .rect.width != .deco_rect.width then .rect.y else .rect.y + .window_rect.y end) \(.window_rect.width)x\(.window_rect.height)"' | slurp | xargs -I {} sh -c 'grim -g "{}" && notify-send " screenshot taken"'
}
function screenshot-output() {
  grim -o $(swaymsg -t get_outputs | jq -r '.[] | select(.focused) | .name') && notify-send " screenshot taken"
}
function clipboard() {
  cliphist list | fuzzel -d -w 80 | cliphist decode | wl-copy
}

"$@"
